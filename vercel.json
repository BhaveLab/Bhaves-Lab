{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/realm",              "destination": "/realm.html" },
    { "source": "/realm/(.*)",         "destination": "/realm.html" },
    { "source": "/consciousness-mirror", "destination": "/consciousness-mirror.html" },
    { "source": "/study-session",      "destination": "/study-session.html" },
    { "source": "/study-yourself",     "destination": "/study-yourself-v2.html" },
    { "source": "/thank-you",          "destination": "/thank-you.html" }
  ]
}
